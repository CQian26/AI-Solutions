# Magic-link token for the BidMatch search profile.
# Get from the daily APEX email or the saved profile URL.
BIDMATCH_SUB=

# Optional: override default lookback window
BIDMATCH_DAYS=7

# Optional: output file path (default: ./bidmatch_<date>.xlsx)
BIDMATCH_OUTPUT=

# Optional SAM.gov REST API key. If unset, SAM.gov calls are skipped.
SAM_API_KEY=

# Optional cache directory. Default: .cache/ (gitignored).
CACHE_DIR=

# Autorun (daily unattended execution) settings
# SMTP host for notification emails (required for autorun)
SMTP_HOST=

# SMTP port (default: 587)
SMTP_PORT=587

# SMTP username (optional, can be empty)
SMTP_USER=

# SMTP password (optional, can be empty)
SMTP_PASSWORD=

# Comma-separated recipient email addresses (required for autorun)
NOTIFY_TO=

# Lookback window for autorun (default: 2 days)
AUTORUN_DAYS=2

# Output directory for autorun results (default: output)
AUTORUN_OUTPUT_DIR=output

# Comma-separated list of CP set-asides to include (default: small_business)
CP_SET_ASIDES=small_business
